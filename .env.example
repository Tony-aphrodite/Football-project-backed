NODE_ENV=development
PORT=3000

# CORS — comma-separated origins. Use * only in development.
CORS_ORIGINS=*

# JWT — Etapa 1
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-me-with-32-byte-random-secret
JWT_REFRESH_SECRET=replace-me-with-different-32-byte-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# AWS DynamoDB — Etapa 1
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_TABLE_NAME=arena_dos_mantos
# Optional: set to http://localhost:8000 to use the dynamodb-local docker image
DYNAMODB_ENDPOINT=

# Google OAuth — Etapa 1
# One client per platform; verify ID tokens against the matching aud.
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_WEB=

# Apple Sign In — Etapa 1
APPLE_BUNDLE_ID=com.arenadosmantos.app
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste the contents of the AuthKey_XXXX.p8 file (multi-line — escape \n if needed)
APPLE_PRIVATE_KEY=

# Twilio Verify — Etapa 1
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# LGPD — text version returned by /auth/lgpd/current. Bump on text changes
# so existing users are re-prompted to consent.
LGPD_CONSENT_VERSION=2026-04-29
LGPD_PRIVACY_POLICY_URL=https://arenadosmantos.com.br/privacidade

# Cloudflare R2 — Etapa 2 (collected early to unblock photo upload)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=arena-dos-mantos-photos
R2_PUBLIC_URL=

# Pagar.me — Etapa 4
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=

# Algolia — Etapa 2 search
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_SEARCH_API_KEY=
ALGOLIA_INDEX_NAME=listings

# Melhor Envio — shipping quotes (https://melhorenvio.com.br)
# Leave blank to use hardcoded fallback estimates
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=true

# Focus NFe — electronic invoice API (https://focusnfe.com.br)
FOCUS_NFE_TOKEN=
FOCUS_NFE_SANDBOX=true
